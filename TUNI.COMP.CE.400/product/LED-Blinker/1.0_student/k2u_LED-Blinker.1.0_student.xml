	<ipxact:description>Same design used for both VEEK boards

# Only have one of the following sets uncommented in the &quot;soc_system.qsf&quot; file, depending on the FPGA board you are using

# Cyclone V SoC Development Kit --&gt;
set_location_assignment PIN_AC18 -to fpga_clk_50
set_location_assignment PIN_AB13 -to fpga_button_pio[1]
set_location_assignment PIN_AA13 -to fpga_button_pio[0]
set_location_assignment PIN_AG11 -to fpga_dipsw_pio[3]
set_location_assignment PIN_AF11 -to fpga_dipsw_pio[2]
set_location_assignment PIN_AH9 -to fpga_dipsw_pio[1]
set_location_assignment PIN_AG10 -to fpga_dipsw_pio[0]
set_location_assignment PIN_AB17 -to fpga_led_pio[3]
set_location_assignment PIN_W15 -to fpga_led_pio[2]
set_location_assignment PIN_Y16 -to fpga_led_pio[1]
set_location_assignment PIN_AK2 -to fpga_led_pio[0]
# &lt;-- Cyclone V SoC Development Kit

# Cyclone V Arrow SoCkit --&gt;
#set_location_assignment PIN_K14 -to fpga_clk_50
#set_location_assignment PIN_AE12 -to fpga_button_pio[1]
#set_location_assignment PIN_AE9 -to fpga_button_pio[0]
#set_location_assignment PIN_AC29 -to fpga_dipsw_pio[3]
#set_location_assignment PIN_AC28 -to fpga_dipsw_pio[2]
#set_location_assignment PIN_V25 -to fpga_dipsw_pio[1]
#set_location_assignment PIN_W25 -to fpga_dipsw_pio[0]
#set_location_assignment PIN_AD7 -to fpga_led_pio[3]
#set_location_assignment PIN_AE11 -to fpga_led_pio[2]
#set_location_assignment PIN_AD10 -to fpga_led_pio[1]
#set_location_assignment PIN_AF10 -to fpga_led_pio[0]
# &lt;-- Cyclone V Arrow SoCkit</ipxact:description>
